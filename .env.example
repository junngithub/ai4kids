# =============================================================================
# Only the values that MUST be in env (boot-time).
# Everything else — Gmail OAuth, lead-notification email, Anthropic Claude
# token, Firecrawl, Tavily — is configured via the admin CMS:
#   /admin/settings (encrypted in the `settings` table)
# =============================================================================

# --- App ---
NEXT_PUBLIC_SITE_URL=https://www.tertiaryinfotech.com
# NextAuth needs an explicit URL for redirects after sign-in / sign-out.
# Set to https://your-prod-domain on Coolify, http://localhost:<port> locally.
AUTH_URL=https://www.tertiaryinfotech.com

# --- Postgres (Coolify-provisioned in prod) ---
DATABASE_URL=postgres://user:pass@localhost:5432/tertiaryinfotech

# --- Auth.js ---
# Signs sessions AND derives the encryption key for the admin Credentials
# store. MUST match across environments that share a DB.
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Initial admin user seed (one-time, used by `pnpm seed:admin`) ---
ADMIN_EMAIL=admin@tertiaryinfotech.com
ADMIN_PASSWORD=change-me-immediately

# --- Local → Remote DB sync (push menus / pages / posts from local → prod) ---
# Generate with: openssl rand -hex 32
# Set the SAME value on local AND production. API rejects all requests if unset.
SYNC_API_TOKEN=
# Local-only — used by scripts/push-to-remote.ts to target prod.
REMOTE_SYNC_URL=https://www.tertiaryinfotech.com
